generator client {
  provider = "prisma-client-js"
}

// Datasource configuration for Neon PostgreSQL (Vercel)
datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Event
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id        String   @id @default(uuid())
  name      String
  eventDate DateTime
  venue     String
  qualifier String
  /// ACTIVE | UPCOMING | COMPLETE
  status    String   @default("ACTIVE")

  arenas  Arena[]
  classes CompetitionClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Arena
// ─────────────────────────────────────────────────────────────────────────────

model Arena {
  id         String @id @default(uuid())
  eventId    String
  name       String
  discipline String
  /// ACTIVE | PAUSED | ARENA_RAKE | COURSE_CHANGE | COMPLETE
  status     String @default("ACTIVE")
  /// Controls the display order on the public dashboard
  sortOrder  Int    @default(0)

  event   Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  classes CompetitionClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// CompetitionClass
// ─────────────────────────────────────────────────────────────────────────────

model CompetitionClass {
  id                 String  @id @default(uuid())
  eventId            String
  arenaId            String
  classCode          String
  name               String
  discipline         String  @default("SHOWJUMPING")
  height             String
  competitionType    String
  feiArticle         String?
  /// 24h time string, e.g. "08:15"
  scheduledStartTime String
  expectedRiders     Int     @default(0)
  sortOrder          Int
  /// PENDING | ACTIVE | COMPLETE
  status             String  @default("PENDING")

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  arena         Arena          @relation(fields: [arenaId], references: [id], onDelete: Cascade)
  runningOrders RunningOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Each classCode must be unique within an event
  @@unique([eventId, classCode])
  @@index([arenaId])
  @@index([eventId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// School — SANESA schools; name is the natural unique key
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id   String @id @default(uuid())
  name String @unique

  riders Rider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Rider — riderNo is the SANESA membership number, globally unique
// ─────────────────────────────────────────────────────────────────────────────

model Rider {
  id       String @id @default(uuid())
  /// SANESA membership number, e.g. "GP11943"
  riderNo  String @unique
  fullName String
  schoolId String

  school        School         @relation(fields: [schoolId], references: [id])
  runningOrders RunningOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Horse — name is the registered name, unique in the system
// ─────────────────────────────────────────────────────────────────────────────

model Horse {
  id   String @id @default(uuid())
  name String @unique
  /// HORSE | PONY
  type String @default("HORSE")

  runningOrders RunningOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// RunningOrder — one row per rider-class entry
//   • A rider can appear in multiple classes (with potentially different horses)
//   • Within a single class, a rider appears at most once
//   • Within a single class, two riders cannot share the same planned order slot
// ─────────────────────────────────────────────────────────────────────────────

model RunningOrder {
  id             String  @id @default(uuid())
  classId        String
  riderId        String
  horseId        String
  plannedOrderNo Int
  actualOrderNo  Int?
  /// 24h time string, e.g. "08:25"
  plannedTime    String?

  /// SCHEDULED | CHECKED_IN | AT_GATE | IN_ARENA | FINISHED |
  /// RESULT_PENDING | RESULT_CONFIRMED | PUBLISHED |
  /// HELD | SCRATCHED | NO_SHOW | ELIMINATED | RETIRED
  status String @default("SCHEDULED")

  orderChanged      Boolean   @default(false)
  orderChangeReason String?
  /// Free-text notes from gate marshal or timer (e.g. "Horse tied up, holding")
  notes             String?

  checkedInAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?

  competitionClass CompetitionClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  rider            Rider            @relation(fields: [riderId], references: [id])
  horse            Horse            @relation(fields: [horseId], references: [id])

  result        Result?
  statusHistory StatusHistory[]
  timerEvents   TimerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Prevent two riders at the same position in the same class
  @@unique([classId, plannedOrderNo])
  /// Prevent the same rider appearing twice in the same class
  @@unique([classId, riderId])
  @@index([classId])
  @@index([riderId])
  @@index([horseId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Result — one per RunningOrder, created when a round is finished
// ─────────────────────────────────────────────────────────────────────────────

model Result {
  id             String  @id @default(uuid())
  runningOrderId String  @unique
  elapsedSeconds Float?
  faults         Int?
  penalties      Int?
  placing        Int?
  /// PENDING | CONFIRMED | DISPUTED
  resultStatus   String  @default("PENDING")
  published      Boolean @default(false)

  runningOrder RunningOrder @relation(fields: [runningOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resultStatus])
  @@index([published])
}

// ─────────────────────────────────────────────────────────────────────────────
// StatusHistory — immutable audit log; never deleted
// ─────────────────────────────────────────────────────────────────────────────

model StatusHistory {
  id             String  @id @default(uuid())
  runningOrderId String
  oldStatus      String?
  newStatus      String
  reason         String?
  changedBy      String?
  /// Timestamp of when this status change occurred
  changedAt      DateTime @default(now())

  runningOrder RunningOrder @relation(fields: [runningOrderId], references: [id], onDelete: Cascade)

  @@index([runningOrderId])
  @@index([changedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TimerEvent — raw timer actions (start / finish / correction)
// ─────────────────────────────────────────────────────────────────────────────

model TimerEvent {
  id             String @id @default(uuid())
  runningOrderId String
  /// START | FINISH | FAULT_ADD | FAULT_REMOVE | CORRECTION
  eventType      String
  eventTime      DateTime @default(now())
  source         String?
  capturedBy     String?

  runningOrder RunningOrder @relation(fields: [runningOrderId], references: [id], onDelete: Cascade)

  @@index([runningOrderId])
  @@index([eventType])
}
